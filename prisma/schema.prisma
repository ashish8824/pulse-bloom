// prisma/schema.prisma

datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

// ─────────────────────────────────────────────────────────────────
// PLAN ENUM
// ─────────────────────────────────────────────────────────────────
enum Plan {
  free
  pro
  enterprise
}

// ─────────────────────────────────────────────────────────────────
// SUBSCRIPTION STATUS ENUM
// ─────────────────────────────────────────────────────────────────
enum SubscriptionStatus {
  active
  cancelled
  past_due
  trialing
  incomplete
}

// ─────────────────────────────────────────────────────────────────
// NOTIFICATION TYPE ENUM
// ─────────────────────────────────────────────────────────────────
enum NotificationType {
  STREAK_MILESTONE
  BURNOUT_RISK_CHANGED
  WEEKLY_SUMMARY
  BADGE_EARNED
  CHALLENGE_UPDATE
  MOOD_REMINDER
  HABIT_REMINDER
}

// ─────────────────────────────────────────────────────────────────
// MILESTONE TYPE ENUM  ← NEW
//
// Each value maps to a distinct achievement event.
//
// Habit streaks:
//   HABIT_STREAK_7 … HABIT_STREAK_365  → streak hit that day count
//
// Mood streaks:
//   MOOD_STREAK_7 / _14 / _30          → consecutive days of mood logging
//
// Special events:
//   FIRST_MOOD_ENTRY   → first ever mood logged
//   BEST_WEEK_MOOD     → user's highest weekly average mood ever
//   BURNOUT_RECOVERY   → burnout risk dropped from High → Low
//
// Adding a new milestone type = add the enum value here + add a
// check in milestone.service.ts. No other files need changing.
// ─────────────────────────────────────────────────────────────────
enum MilestoneType {
  FIRST_MOOD_ENTRY
  HABIT_STREAK_7
  HABIT_STREAK_14
  HABIT_STREAK_21
  HABIT_STREAK_30
  HABIT_STREAK_60
  HABIT_STREAK_90
  HABIT_STREAK_100
  HABIT_STREAK_180
  HABIT_STREAK_365
  MOOD_STREAK_7
  MOOD_STREAK_14
  MOOD_STREAK_30
  BEST_WEEK_MOOD
  BURNOUT_RECOVERY
}

// ─────────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────────
model User {
  id                   String   @id @default(uuid())
  email                String   @unique
  password             String
  name                 String
  isVerified           Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // ── Monetization ──────────────────────────────────────────────
  plan                 Plan     @default(free)
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique

  // ── Engagement (Phase 2) ──────────────────────────────────────
  weeklyDigestOn       Boolean  @default(true)
  moodReminderTime     String?
  moodReminderOn       Boolean  @default(false)

  moods              MoodEntry[]
  habits             Habit[]
  aiInsight          AiInsight?
  refreshTokens      RefreshToken[]
  emailVerifications EmailVerification[]
  passwordResets     PasswordReset[]
  subscription       Subscription?
  notifications      Notification[]
  milestones         Milestone[]   
  badges       Badge[]
  challengesCreated  Challenge[]            @relation("ChallengeCreator")
  challengeParticipations ChallengeParticipant[]

  @@index([moodReminderOn, moodReminderTime])
}

// ─────────────────────────────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────────────────────────────
model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  relatedId String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────
// MILESTONE  ← NEW
//
// Stores achievement milestones earned by a user over time.
// Displayed as a chronological timeline on GET /api/milestones.
//
// Design decisions:
//
//   habitId: optional — only set for habit-specific milestones
//            (e.g. HABIT_STREAK_30 links back to the habit).
//            Mood and account milestones leave this null.
//
//   value: optional numeric context — e.g. for BEST_WEEK_MOOD
//          stores the actual avg score so the timeline can display
//          "Your best week: avg 4.8" without a join.
//
//   @@unique([userId, type, habitId]):
//     Prevents the same milestone from being awarded twice for the
//     same habit. For mood/account milestones (habitId = null),
//     Postgres treats NULL as distinct — so FIRST_MOOD_ENTRY can
//     only be awarded once (one row per userId + type + null).
//
//   Indexes:
//     [userId, achievedAt] → timeline query sorted newest first
//     [userId, type]       → fast "already awarded?" idempotency check
// ─────────────────────────────────────────────────────────────────
model Milestone {
  id         String        @id @default(uuid())
  userId     String
  type       MilestoneType
  habitId    String?       // null for mood / account milestones
  value      Float?        // optional numeric context (e.g. best week avg score)
  achievedAt DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, habitId])
  @@index([userId, achievedAt])
  @@index([userId, type])
}

// ─────────────────────────────────────────────────────────────────
// SUBSCRIPTION
// ─────────────────────────────────────────────────────────────────
model Subscription {
  id                   String             @id @default(uuid())
  userId               String             @unique
  plan                 Plan
  status               SubscriptionStatus @default(trialing)
  stripeSubscriptionId String?            @unique
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeSubscriptionId])
}

// ─────────────────────────────────────────────────────────────────
// REFRESH TOKEN
// ─────────────────────────────────────────────────────────────────
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────
// EMAIL VERIFICATION
// ─────────────────────────────────────────────────────────────────
model EmailVerification {
  id        String   @id @default(uuid())
  otp       String
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────
// PASSWORD RESET
// ─────────────────────────────────────────────────────────────────
model PasswordReset {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────
// MOOD ENTRY
// ─────────────────────────────────────────────────────────────────
model MoodEntry {
  id        String   @id @default(uuid())
  moodScore Int
  emoji     String
  journalId String?
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
}

// ─────────────────────────────────────────────────────────────────
// HABIT
// ─────────────────────────────────────────────────────────────────
enum HabitFrequency {
  daily
  weekly
}

enum HabitCategory {
  health
  fitness
  learning
  productivity
  mindfulness
  custom
}

model Habit {
  id            String         @id @default(uuid())
  title         String
  description   String?
  frequency     HabitFrequency
  category      HabitCategory  @default(custom)
  color         String?
  icon          String?
  targetPerWeek Int?
  sortOrder     Int            @default(0)
  isArchived    Boolean        @default(false)
  reminderTime  String?
  reminderOn    Boolean        @default(false)
  userId        String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs HabitLog[]

  @@unique([userId, title, frequency])
  @@index([userId])
  @@index([reminderOn, reminderTime])
}

// ─────────────────────────────────────────────────────────────────
// HABIT LOG
// ─────────────────────────────────────────────────────────────────
model HabitLog {
  id        String   @id @default(uuid())
  habitId   String
  date      DateTime
  completed Boolean  @default(true)
  note      String?
  createdAt DateTime @default(now())

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([habitId])
}

// ─────────────────────────────────────────────────────────────────
// AI INSIGHT CACHE
// ─────────────────────────────────────────────────────────────────
model AiInsight {
  id          String   @id @default(uuid())
  userId      String
  insights    Json
  dataHash    String
  generatedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@index([userId])
}



// ─────────────────────────────────────────────────────────────────
// PHASE 4 — GAMIFICATION SCHEMA ADDITIONS
//
// Add these blocks into your existing schema.prisma.
//
// Migration command after adding:
//   npx prisma migrate dev --name phase4_gamification
//
// WHAT CHANGES:
//   1. New enum: BadgeType          → all 6 badge identifiers
//   2. New model: Badge             → earned badge records per user
//   3. New model: Challenge         → user-created or system challenges
//   4. New model: ChallengeParticipant → join table (user ↔ challenge)
//   5. User model additions:        → add `badges` and `challenges` relations
//   6. NotificationType additions:  → BADGE_EARNED & CHALLENGE_UPDATE already exist ✅
//
// ─────────────────────────────────────────────────────────────────

// ─────────────────────────────────────────────────────────────────
// BADGE TYPE ENUM
//
// WHY AN ENUM (not a string)?
//   Enums are enforced at the DB level — impossible to insert a typo.
//   Adding a new badge = add the enum value here + add a check in
//   badge.service.ts. Nothing else changes.
//
// BADGE UNLOCK CONDITIONS (enforced in badge.service.ts):
//   FIRST_STEP      → first mood entry logged
//   WEEK_ONE        → 7-day consecutive mood logging streak
//   IRON_WILL       → 30-day streak on any single habit
//   MINDFUL_MONTH   → mood logged every day for a full calendar month
//   RESILIENT       → burnout risk dropped from High → Low
//   CENTURION       → 100-day streak on any single habit
// ─────────────────────────────────────────────────────────────────
enum BadgeType {
  FIRST_STEP
  WEEK_ONE
  IRON_WILL
  MINDFUL_MONTH
  RESILIENT
  CENTURION
}

// ─────────────────────────────────────────────────────────────────
// BADGE
//
// One row per badge earned per user. A user can earn each badge
// only once — enforced by @@unique([userId, type]).
//
// WHY NOT ON USER MODEL?
//   Badges are a many-per-user relation. A separate table lets us:
//   - Store earnedAt per badge
//   - Add new badges without altering the User table
//   - Query "who earned IRON_WILL?" efficiently via the type index
//
// relatedId: optional contextual link — e.g. for IRON_WILL it stores
//   the habitId so the badge detail screen can deep-link to that habit.
//   For FIRST_STEP or WEEK_ONE there's no specific entity to link.
//
// Indexes:
//   [userId]           → GET /api/badges for one user (primary use)
//   [userId, type]     → idempotency check before awarding
//   [type]             → leaderboard / admin queries ("all CENTURION holders")
// ─────────────────────────────────────────────────────────────────
model Badge {
  id        String    @id @default(uuid())
  userId    String
  type      BadgeType
  relatedId String?   // e.g. habitId for IRON_WILL / CENTURION
  earnedAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
  @@index([userId, type])
  @@index([type])
}

// ─────────────────────────────────────────────────────────────────
// CHALLENGE
//
// A challenge is a time-boxed habit goal that one user creates and
// others can join. The creator is also a participant (auto-joined).
//
// FIELD DECISIONS:
//
//   habitId: optional — a challenge can be habit-specific ("do 20
//     push-ups daily for 30 days") or free-form ("any habit, 30 days").
//     When set, ChallengeParticipant.completionsCount increments each
//     time the linked habit is completed by that participant.
//     When null, participants manually track via POST /complete.
//
//   targetDays: the challenge duration. Combined with startDate/endDate
//     to calculate progress percentage on the frontend.
//
//   isPublic: true  → appears in GET /api/challenges (community list)
//             false → invite-only, accessible only by direct link/code
//
//   isActive: soft-disable without deleting. Set to false when
//     endDate passes (via a cron job in a future phase).
//
//   joinCode: 8-char random code for private challenges. Frontend
//     shows a "Join with code" input. NOT a security token — just
//     a friendly invite code.
//
// Indexes:
//   [createdBy]            → "my challenges" query
//   [isPublic, isActive]   → public challenges list (most common query)
//   [habitId]              → when completing a habit, find linked challenges
// ─────────────────────────────────────────────────────────────────
model Challenge {
  id          String   @id @default(uuid())
  title       String
  description String?
  habitId     String?  // optional — links to a specific habit
  targetDays  Int
  startDate   DateTime
  endDate     DateTime
  isPublic    Boolean  @default(true)
  isActive    Boolean  @default(true)
  joinCode    String   @unique // 8-char random code for private invite
  createdBy   String   // userId of creator

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator      User                   @relation("ChallengeCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  participants ChallengeParticipant[]

  @@index([createdBy])
  @@index([isPublic, isActive])
  @@index([habitId])
}

// ─────────────────────────────────────────────────────────────────
// CHALLENGE PARTICIPANT
//
// Join table between User and Challenge.
// One row per (user, challenge) pair.
//
// completionsCount: incremented each time the user completes
//   the linked habit (or manually marks a day complete).
//   Progress % = (completionsCount / targetDays) × 100
//
// isCompleted: set to true when completionsCount >= targetDays.
//   Triggers BADGE_EARNED notification and badge award check.
//
// completedAt: null until isCompleted = true. Stored so the
//   leaderboard can sort by who finished first.
//
// @@unique([challengeId, userId]) — one entry per user per challenge.
//   Prevents double-joining. DB-level safety net against race conditions.
//
// Indexes:
//   [userId]       → "my joined challenges" query
//   [challengeId]  → leaderboard for a specific challenge
// ─────────────────────────────────────────────────────────────────
model ChallengeParticipant {
  id               String    @id @default(uuid())
  challengeId      String
  userId           String
  completionsCount Int       @default(0)
  isCompleted      Boolean   @default(false)
  completedAt      DateTime?
  joinedAt         DateTime  @default(now())

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
  @@index([userId])
  @@index([challengeId])
}
