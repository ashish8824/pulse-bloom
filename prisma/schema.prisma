// prisma/schema.prisma

datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

// ─────────────────────────────────────────────────────────────────
// PLAN ENUM
// ─────────────────────────────────────────────────────────────────
enum Plan {
  free
  pro
  enterprise
}

// ─────────────────────────────────────────────────────────────────
// SUBSCRIPTION STATUS ENUM
// ─────────────────────────────────────────────────────────────────
enum SubscriptionStatus {
  active
  cancelled
  past_due
  trialing
  incomplete
}

// ─────────────────────────────────────────────────────────────────
// NOTIFICATION TYPE ENUM  ← NEW
//
// Each value maps to a distinct trigger in the application:
//
//   STREAK_MILESTONE     → habit streak hits 7, 14, 21, 30, 60, 90, 100, 180, 365
//   BURNOUT_RISK_CHANGED → burnout level shifted (Low→Moderate, Moderate→High, etc.)
//   WEEKLY_SUMMARY       → Saturday digest was sent (in-app record of the email)
//   BADGE_EARNED         → achievement badge unlocked (Phase 4)
//   CHALLENGE_UPDATE     → challenge joined / completed (Phase 4)
//   MOOD_REMINDER        → mood check-in reminder fired (in-app record)
//   HABIT_REMINDER       → habit reminder fired (in-app record)
//
// New types can be added here without touching any other enum —
// the notification module is generic and type-agnostic.
// ─────────────────────────────────────────────────────────────────
enum NotificationType {
  STREAK_MILESTONE
  BURNOUT_RISK_CHANGED
  WEEKLY_SUMMARY
  BADGE_EARNED
  CHALLENGE_UPDATE
  MOOD_REMINDER
  HABIT_REMINDER
}

// ─────────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────────
model User {
  id                   String   @id @default(uuid())
  email                String   @unique
  password             String
  name                 String
  isVerified           Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // ── Monetization ──────────────────────────────────────────────
  plan                 Plan     @default(free)
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique

  // ── Engagement (Phase 2) ──────────────────────────────────────
  weeklyDigestOn       Boolean  @default(true)
  moodReminderTime     String?
  moodReminderOn       Boolean  @default(false)

  moods              MoodEntry[]
  habits             Habit[]
  aiInsight          AiInsight?
  refreshTokens      RefreshToken[]
  emailVerifications EmailVerification[]
  passwordResets     PasswordReset[]
  subscription       Subscription?
  notifications      Notification[]       // ← NEW relation

  @@index([moodReminderOn, moodReminderTime])
}

// ─────────────────────────────────────────────────────────────────
// NOTIFICATION  ← NEW
//
// Stores in-app notifications for a user.
//
// Design decisions:
//
//   isRead: false → appears in the unread badge count
//          true  → appears in the history list but not the badge
//
//   relatedId: optional foreign-key-style pointer to the entity that
//              triggered this notification. Not a true FK because the
//              target model varies by type:
//                STREAK_MILESTONE → habitId
//                BURNOUT_RISK_CHANGED → null (no single entity)
//                BADGE_EARNED → badgeId (Phase 4)
//              Storing it here lets the frontend deep-link to the
//              relevant screen without a separate lookup.
//
//   Indexes:
//     [userId]             → all list queries filter by userId
//     [userId, isRead]     → unread count query: WHERE userId=X AND isRead=false
//     [userId, createdAt]  → paginated history: WHERE userId=X ORDER BY createdAt DESC
//     [createdAt]          → cleanup cron: DELETE WHERE createdAt < 90 days ago
//
// Retention: notifications older than 90 days are deleted by a
// cleanup cron (runs daily) to keep the table lean.
// ─────────────────────────────────────────────────────────────────
model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String           // short, bold — e.g. "🔥 7-Day Streak!"
  message   String           // full body — e.g. "You've completed Morning Meditation 7 days in a row."
  isRead    Boolean          @default(false)
  relatedId String?          // optional: habitId, badgeId, etc. for deep-linking
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])     // fast unread count
  @@index([userId, createdAt])  // fast paginated history
  @@index([createdAt])          // fast cleanup cron
}

// ─────────────────────────────────────────────────────────────────
// SUBSCRIPTION
// ─────────────────────────────────────────────────────────────────
model Subscription {
  id                   String             @id @default(uuid())
  userId               String             @unique
  plan                 Plan
  status               SubscriptionStatus @default(trialing)
  stripeSubscriptionId String?            @unique
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeSubscriptionId])
}

// ─────────────────────────────────────────────────────────────────
// REFRESH TOKEN
// ─────────────────────────────────────────────────────────────────
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────
// EMAIL VERIFICATION
// ─────────────────────────────────────────────────────────────────
model EmailVerification {
  id        String   @id @default(uuid())
  otp       String
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────
// PASSWORD RESET
// ─────────────────────────────────────────────────────────────────
model PasswordReset {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────
// MOOD ENTRY
// ─────────────────────────────────────────────────────────────────
model MoodEntry {
  id        String   @id @default(uuid())
  moodScore Int
  emoji     String
  journalId String?
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
}

// ─────────────────────────────────────────────────────────────────
// HABIT
// ─────────────────────────────────────────────────────────────────
enum HabitFrequency {
  daily
  weekly
}

enum HabitCategory {
  health
  fitness
  learning
  mindfulness
  productivity
  custom
}

model Habit {
  id            String         @id @default(uuid())
  title         String
  description   String?
  frequency     HabitFrequency
  category      HabitCategory  @default(custom)
  color         String?
  icon          String?
  targetPerWeek Int?
  sortOrder     Int            @default(0)
  isArchived    Boolean        @default(false)
  reminderTime  String?
  reminderOn    Boolean        @default(false)
  userId        String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs HabitLog[]

  @@unique([userId, title, frequency])
  @@index([userId])
  @@index([reminderOn, reminderTime])
}

// ─────────────────────────────────────────────────────────────────
// HABIT LOG
// ─────────────────────────────────────────────────────────────────
model HabitLog {
  id        String   @id @default(uuid())
  habitId   String
  date      DateTime
  completed Boolean  @default(true)
  note      String?
  createdAt DateTime @default(now())

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([habitId])
}

// ─────────────────────────────────────────────────────────────────
// AI INSIGHT CACHE
// ─────────────────────────────────────────────────────────────────
model AiInsight {
  id          String   @id @default(uuid())
  userId      String
  insights    Json
  dataHash    String
  generatedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@index([userId])
}
