// prisma/schema.prisma

datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

// ─────────────────────────────────────────────────────────────────
// PLAN ENUM
// ─────────────────────────────────────────────────────────────────
enum Plan {
  free
  pro
  enterprise
}

// ─────────────────────────────────────────────────────────────────
// SUBSCRIPTION STATUS ENUM
// ─────────────────────────────────────────────────────────────────
enum SubscriptionStatus {
  active
  cancelled
  past_due
  trialing
  incomplete
}

// ─────────────────────────────────────────────────────────────────
// NOTIFICATION TYPE ENUM
// ─────────────────────────────────────────────────────────────────
enum NotificationType {
  STREAK_MILESTONE
  BURNOUT_RISK_CHANGED
  WEEKLY_SUMMARY
  BADGE_EARNED
  CHALLENGE_UPDATE
  MOOD_REMINDER
  HABIT_REMINDER
}

// ─────────────────────────────────────────────────────────────────
// MILESTONE TYPE ENUM  ← NEW
//
// Each value maps to a distinct achievement event.
//
// Habit streaks:
//   HABIT_STREAK_7 … HABIT_STREAK_365  → streak hit that day count
//
// Mood streaks:
//   MOOD_STREAK_7 / _14 / _30          → consecutive days of mood logging
//
// Special events:
//   FIRST_MOOD_ENTRY   → first ever mood logged
//   BEST_WEEK_MOOD     → user's highest weekly average mood ever
//   BURNOUT_RECOVERY   → burnout risk dropped from High → Low
//
// Adding a new milestone type = add the enum value here + add a
// check in milestone.service.ts. No other files need changing.
// ─────────────────────────────────────────────────────────────────
enum MilestoneType {
  FIRST_MOOD_ENTRY
  HABIT_STREAK_7
  HABIT_STREAK_14
  HABIT_STREAK_21
  HABIT_STREAK_30
  HABIT_STREAK_60
  HABIT_STREAK_90
  HABIT_STREAK_100
  HABIT_STREAK_180
  HABIT_STREAK_365
  MOOD_STREAK_7
  MOOD_STREAK_14
  MOOD_STREAK_30
  BEST_WEEK_MOOD
  BURNOUT_RECOVERY
}

// ─────────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────────
model User {
  id                   String   @id @default(uuid())
  email                String   @unique
  password             String
  name                 String
  isVerified           Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // ── Monetization ──────────────────────────────────────────────
  plan                 Plan     @default(free)
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique

  // ── Engagement (Phase 2) ──────────────────────────────────────
  weeklyDigestOn       Boolean  @default(true)
  moodReminderTime     String?
  moodReminderOn       Boolean  @default(false)

  moods              MoodEntry[]
  habits             Habit[]
  aiInsight          AiInsight?
  refreshTokens      RefreshToken[]
  emailVerifications EmailVerification[]
  passwordResets     PasswordReset[]
  subscription       Subscription?
  notifications      Notification[]
  milestones         Milestone[]          // ← NEW

  @@index([moodReminderOn, moodReminderTime])
}

// ─────────────────────────────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────────────────────────────
model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  relatedId String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────
// MILESTONE  ← NEW
//
// Stores achievement milestones earned by a user over time.
// Displayed as a chronological timeline on GET /api/milestones.
//
// Design decisions:
//
//   habitId: optional — only set for habit-specific milestones
//            (e.g. HABIT_STREAK_30 links back to the habit).
//            Mood and account milestones leave this null.
//
//   value: optional numeric context — e.g. for BEST_WEEK_MOOD
//          stores the actual avg score so the timeline can display
//          "Your best week: avg 4.8" without a join.
//
//   @@unique([userId, type, habitId]):
//     Prevents the same milestone from being awarded twice for the
//     same habit. For mood/account milestones (habitId = null),
//     Postgres treats NULL as distinct — so FIRST_MOOD_ENTRY can
//     only be awarded once (one row per userId + type + null).
//
//   Indexes:
//     [userId, achievedAt] → timeline query sorted newest first
//     [userId, type]       → fast "already awarded?" idempotency check
// ─────────────────────────────────────────────────────────────────
model Milestone {
  id         String        @id @default(uuid())
  userId     String
  type       MilestoneType
  habitId    String?       // null for mood / account milestones
  value      Float?        // optional numeric context (e.g. best week avg score)
  achievedAt DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, habitId])
  @@index([userId, achievedAt])
  @@index([userId, type])
}

// ─────────────────────────────────────────────────────────────────
// SUBSCRIPTION
// ─────────────────────────────────────────────────────────────────
model Subscription {
  id                   String             @id @default(uuid())
  userId               String             @unique
  plan                 Plan
  status               SubscriptionStatus @default(trialing)
  stripeSubscriptionId String?            @unique
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeSubscriptionId])
}

// ─────────────────────────────────────────────────────────────────
// REFRESH TOKEN
// ─────────────────────────────────────────────────────────────────
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────
// EMAIL VERIFICATION
// ─────────────────────────────────────────────────────────────────
model EmailVerification {
  id        String   @id @default(uuid())
  otp       String
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────
// PASSWORD RESET
// ─────────────────────────────────────────────────────────────────
model PasswordReset {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────
// MOOD ENTRY
// ─────────────────────────────────────────────────────────────────
model MoodEntry {
  id        String   @id @default(uuid())
  moodScore Int
  emoji     String
  journalId String?
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
}

// ─────────────────────────────────────────────────────────────────
// HABIT
// ─────────────────────────────────────────────────────────────────
enum HabitFrequency {
  daily
  weekly
}

enum HabitCategory {
  health
  fitness
  learning
  productivity
  mindfulness
  custom
}

model Habit {
  id            String         @id @default(uuid())
  title         String
  description   String?
  frequency     HabitFrequency
  category      HabitCategory  @default(custom)
  color         String?
  icon          String?
  targetPerWeek Int?
  sortOrder     Int            @default(0)
  isArchived    Boolean        @default(false)
  reminderTime  String?
  reminderOn    Boolean        @default(false)
  userId        String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs HabitLog[]

  @@unique([userId, title, frequency])
  @@index([userId])
  @@index([reminderOn, reminderTime])
}

// ─────────────────────────────────────────────────────────────────
// HABIT LOG
// ─────────────────────────────────────────────────────────────────
model HabitLog {
  id        String   @id @default(uuid())
  habitId   String
  date      DateTime
  completed Boolean  @default(true)
  note      String?
  createdAt DateTime @default(now())

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([habitId])
}

// ─────────────────────────────────────────────────────────────────
// AI INSIGHT CACHE
// ─────────────────────────────────────────────────────────────────
model AiInsight {
  id          String   @id @default(uuid())
  userId      String
  insights    Json
  dataHash    String
  generatedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@index([userId])
}
